# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated embeddings (72MB, rebuild with: npm run build:embeddings)
/public/hadith-embeddings.bin
/.cache/

# SQLite database (decompressed from hadith.db.gz at build time)
/data/hadith.db
/data/hadith.db-shm
/data/hadith.db-wal

# source hadith JSON (175MB, see README for download instructions)
/data/hadith-json

# cached ML model (downloaded at build time via prebuild)
# committed so Vercel can use local_files_only without downloading

